                                </tr>
                                <tr>
                                    <td>Français</td>
                                    <td>Dictée</td>
                                    <td><strong>16/20</strong></td>
                                    <td>6ème A</td>
                                    <td>19 Mars 2026</td>
                                </tr>
                                <tr>
                                    <td>Anglais</td>
                                    <td>Compréhension</td>
                                    <td><strong>14/20</strong></td>
