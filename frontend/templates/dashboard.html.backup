    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ============ STATE ============
        let currentUser = {
            name: 'Admin',
            role: 'admin',
            email: 'admin@example.com',
            roleText: 'Administrateur'
        };

        let charts = {};

        // ============ INITIALIZATION ============
        document.addEventListener('DOMContentLoaded', function() {
            // Get role from URL
            const urlParams = new URLSearchParams(window.location.search);
            const role = urlParams.get('view') || 'admin';
            
            // Update current user
            const userInfo = {
                admin: { name: 'Admin', email: 'admin@example.com', roleText: 'Administrateur' },
                teacher: { name: 'Professeur Dupont', email: 'prof@example.com', roleText: 'Enseignant' },
                student: { name: 'Alice Dupont', email: 'alice@example.com', roleText: 'Étudiant' }
            };
            
            currentUser.role = role;
            currentUser.name = userInfo[role].name;
            currentUser.email = userInfo[role].email;
            currentUser.roleText = userInfo[role].roleText;
            
            // Setup UI based on role
            setupRoleBasedUI();
            updateUserInfo();
            
            // Initialize charts
            setTimeout(() => {
                initCharts();
            }, 300);
        });

        // ============ ROLE-BASED UI SETUP ============
        function setupRoleBasedUI() {
            const menuHTML = {
                admin: `
                    <div class="nav-label">MENU</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link active" onclick="showSection('adminDashboard', this)">
                            <i class="nav-icon bi bi-house"></i>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </div>

                    <div class="nav-label">GESTION</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('studentsAdmin', this)">
                            <i class="nav-icon bi bi-people"></i>
                            <span class="nav-text">Étudiants</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('teachersAdmin', this)">
                            <i class="nav-icon bi bi-person-square"></i>
                            <span class="nav-text">Professeurs</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('classesAdmin', this)">
                            <i class="nav-icon bi bi-building"></i>
                            <span class="nav-text">Classes</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('scheduleAdmin', this)">
                            <i class="nav-icon bi bi-calendar-event"></i>
                            <span class="nav-text">Emploi du Temps</span>
                        </a>
                    </div>
                `,
                teacher: `
                    <div class="nav-label">MENU</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link active" onclick="showSection('teacherDashboard', this)">
                            <i class="nav-icon bi bi-house"></i>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </div>

                    <div class="nav-label">GESTION</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('myClasses', this)">
                            <i class="nav-icon bi bi-building"></i>
                            <span class="nav-text">Mes Classes</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('myEvaluations', this)">
                            <i class="nav-icon bi bi-pencil-square"></i>
                            <span class="nav-text">Évaluations</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('mySchedule', this)">
                            <i class="nav-icon bi bi-calendar-event"></i>
                            <span class="nav-text">Mon Emploi du Temps</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('gradesManagement', this)">
                            <i class="nav-icon bi bi-pencil"></i>
                            <span class="nav-text">Saisir les Notes</span>
                        </a>
                    </div>
                `,
                student: `
                    <div class="nav-label">MENU</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link active" onclick="showSection('studentDashboard', this)">
                            <i class="nav-icon bi bi-house"></i>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </div>

                    <div class="nav-label">CONSULTATION</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('myGrades', this)">
                            <i class="nav-icon bi bi-star"></i>
                            <span class="nav-text">Mes Notes</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="#" class="nav-link" onclick="showSection('mySchedule', this)">
                            <i class="nav-icon bi bi-calendar-event"></i>
                            <span class="nav-text">Mon Emploi du Temps</span>
                        </a>
                    </div>
                `
            };

            document.getElementById('sidebarMenu').innerHTML = menuHTML[currentUser.role] || menuHTML.admin;

            // Show appropriate dashboard
            const dashboards = document.querySelectorAll('[id$="Dashboard"]');
            dashboards.forEach(d => d.classList.remove('active'));
            
            const dashboardId = currentUser.role === 'admin' ? 'adminDashboard' : 
                               currentUser.role === 'teacher' ? 'teacherDashboard' : 
                               'studentDashboard';
            
            const dashboard = document.getElementById(dashboardId);
            if (dashboard) {
                dashboard.classList.add('active');
                document.getElementById('sectionTitle').textContent = 
                    currentUser.role === 'admin' ? 'Dashboard Admin' :
                    currentUser.role === 'teacher' ? 'Dashboard Professeur' :
                    'Dashboard Étudiant';
            }
        }

        // ============ SECTION NAVIGATION ============
        function showSection(sectionName, element) {
            const sections = document.querySelectorAll('.section');
            sections.forEach(s => s.classList.remove('active'));
            
            const section = document.getElementById(sectionName);
            if (section) {
                section.classList.add('active');
                
                const titles = {
                    adminDashboard: 'Dashboard Admin',
                    teacherDashboard: 'Dashboard Professeur',
                    studentDashboard: 'Dashboard Étudiant',
                    studentsAdmin: 'Gestion des Étudiants',
                    teachersAdmin: 'Gestion des Professeurs',
                    classesAdmin: 'Gestion des Classes',
                    scheduleAdmin: 'Emploi du Temps',
                    myClasses: 'Mes Classes',
                    myEvaluations: 'Évaluations',
                    mySchedule: 'Mon Emploi du Temps',
                    gradesManagement: 'Saisir les Notes',
                    myGrades: 'Mes Notes'
                };
                
                document.getElementById('sectionTitle').textContent = titles[sectionName] || sectionName;
            }
            
            // Update active nav link
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
            });
            
            if (element) {
                element.classList.add('active');
            }
        }

        // ============ USER INFO ============
        function updateUserInfo() {
            document.getElementById('userName').textContent = currentUser.name;
            document.getElementById('userRole').textContent = currentUser.roleText;
            document.getElementById('userInitial').textContent = currentUser.name.charAt(0).toUpperCase();
        }

        // ============ CHARTS INITIALIZATION ============
        function initCharts() {
            if (currentUser.role === 'admin') {
                initAdminCharts();
            } else if (currentUser.role === 'teacher') {
                initTeacherCharts();
            } else if (currentUser.role === 'student') {
                initStudentCharts();
            }
        }

        function initAdminCharts() {
            const ctx1 = document.getElementById('adminChart1');
            if (ctx1) {
                charts.admin1 = new Chart(ctx1, {
                    type: 'doughnut',
                    data: {
                        labels: ['6ème', '5ème', '4ème', '3ème'],
                        datasets: [{
                            data: [450, 520, 480, 590],
                            backgroundColor: ['#9370db', '#4bc0c0', '#ffa07a', '#87ceeb'],
                            borderColor: 'rgba(30, 30, 45, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom', labels: { color: '#e0e0e0' } } }
                    }
                });
            }

            const ctx2 = document.getElementById('adminChart2');
            if (ctx2) {
                charts.admin2 = new Chart(ctx2, {
                    type: 'bar',
                    data: {
                        labels: ['Étudiants', 'Professeurs', 'Personnel', 'Classes'],
                        datasets: [{
                            label: 'Nombre',
                            data: [2547, 156, 89, 42],
                            backgroundColor: ['#9370db', '#4bc0c0', '#ffa07a', '#87ceeb'],
                            borderRadius: 8,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        indexAxis: 'y',
                        plugins: { 
                            legend: { display: false }
                        },
                        scales: {
                            x: { ticks: { color: '#e0e0e0' }, grid: { color: 'rgba(255,255,255,0.1)' } },
                            y: { ticks: { color: '#e0e0e0' }, grid: { color: 'rgba(255,255,255,0.1)' } }
                        }
                    }
                });
            }
        }

        function initTeacherCharts() {
            const ctx1 = document.getElementById('teacherChart1');
            if (ctx1) {
                charts.teacher1 = new Chart(ctx1, {
                    type: 'bar',
                    data: {
                        labels: ['6ème A', '6ème B', '5ème A', '5ème B'],
                        datasets: [{
                            label: 'Étudiants',
                            data: [28, 26, 30, 28],
                            backgroundColor: '#9370db',
                            borderRadius: 8,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { ticks: { color: '#e0e0e0' }, grid: { color: 'rgba(255,255,255,0.1)' } },
                            x: { ticks: { color: '#e0e0e0' }, grid: { display: false } }
                        }
                    }
                });
            }

            const ctx2 = document.getElementById('teacherChart2');
            if (ctx2) {
                charts.teacher2 = new Chart(ctx2, {
                    type: 'line',
                    data: {
                        labels: ['6ème A', '6ème B', '5ème A', '5ème B'],
                        datasets: [{
                            label: 'Assiduité (%)',
                            data: [92, 88, 95, 90],
                            borderColor: '#4bc0c0',
                            backgroundColor: 'rgba(75, 192, 192, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { ticks: { color: '#e0e0e0' }, grid: { color: 'rgba(255,255,255,0.1)' } },
                            x: { ticks: { color: '#e0e0e0' }, grid: { display: false } }
                        }
                    }
                });
            }
        }

        function initStudentCharts() {
            const ctx1 = document.getElementById('studentChart1');
            if (ctx1) {
                charts.student1 = new Chart(ctx1, {
                    type: 'radar',
                    data: {
                        labels: ['Maths', 'Français', 'Anglais', 'Histoire', 'Sciences'],
                        datasets: [{
                            label: 'Mes Notes',
                            data: [18, 16, 14, 15, 17],
                            borderColor: '#9370db',
                            backgroundColor: 'rgba(147, 112, 219, 0.2)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            r: { 
                                ticks: { color: '#e0e0e0', backdropColor: 'transparent' },
                                grid: { color: 'rgba(255,255,255,0.1)' }
                            }
                        }
                    }
                });
            }

            const ctx2 = document.getElementById('studentChart2');
            if (ctx2) {
                charts.student2 = new Chart(ctx2, {
                    type: 'doughnut',
                    data: {
                        labels: ['Excellent', 'Très bien', 'Bien'],
                        datasets: [{
                            data: [45, 35, 20],
                            backgroundColor: ['#4bc0c0', '#9370db', '#ffa07a'],
                            borderColor: 'rgba(30, 30, 45, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom', labels: { color: '#e0e0e0' } } }
                    }
                });
            }
        }

        // ============ ACTIONS ============
        function logout() {
            if (confirm('Êtes-vous sûr de vouloir vous déconnecter ?')) {
                window.location.href = './index.html';
            }
        }

        function createProject() {
            alert('Créer un nouveau projet');
        }

        function createEvaluation() {
            alert('Créer une nouvelle évaluation');
        }
    </script>
</body>
</html>
