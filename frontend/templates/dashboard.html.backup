                                    <td><select style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 5px; border-radius: 4px;"><option>Excellent</option><option>Très bien</option><option>Bien</option></select></td>
